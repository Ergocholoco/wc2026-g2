FOOTBALL_API_KEY=your_key_here
ADMIN_PASSWORD=your_admin_password
PORT=3003
# PostgreSQL connection string. On Railway, add a PostgreSQL service to your
# project and it will inject DATABASE_URL automatically — no manual setup needed.
# For local development, point this at a local Postgres instance, e.g.:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/quiniela
DATABASE_URL=
SCORING_MODE=advanced
PRIZE_1ST=
PRIZE_2ND=
PRIZE_3RD=
ENTRY_FEE=

FOOTBALL_API_KEY=your_key_here
ADMIN_PASSWORD=your_admin_password
PORT=3003
# Railway's free plan has no persistent volumes — /tmp is local disk that
# survives while the container is running, but resets on every restart/redeploy.
# See README.md "Database storage" for what this means in practice.
DB_PATH=/tmp/quiniela.db
SCORING_MODE=standard
PRIZE_1ST=
PRIZE_2ND=
PRIZE_3RD=
ENTRY_FEE=
